//! Main indexing and search interface
//!
//! This crate provides the main interface for building indices and executing searches.

#![no_std]

extern crate alloc;

use alloc::vec::Vec;
use alloc::collections::BTreeMap;





// Re-export core types for convenience
pub use leit_core::{EntityId, FieldId, TermId, DocId, Hit, Score, Projection};
pub use leit_query::{QueryProgram, QueryBuilder};
pub use leit_postings::{InMemoryPostings, TermDictionary, Posting, PostingsList};
pub use leit_collect::Collector;

/// Execution plan for a query
#[derive(Debug, Clone)]
pub struct ExecutionPlan {
    query: QueryProgram,
}

impl ExecutionPlan {
    pub fn new(query: QueryProgram) -> Self {
        Self { query }
    }
}

/// Workspace for query execution
#[derive(Debug, Default)]
pub struct ExecutionWorkspace {
    // Placeholder for execution state
}

impl ExecutionWorkspace {
    pub fn new() -> Self {
        Self::default()
    }
}

/// Builder for constructing in-memory indices
pub struct InMemoryIndexBuilder {
    postings: InMemoryPostings,
    term_dict: TermDictionary,
    next_doc_id: u32,
}

impl InMemoryIndexBuilder {
    pub fn new() -> Self {
        Self {
            postings: InMemoryPostings::new(),
            term_dict: TermDictionary::new(),
            next_doc_id: 0,
        }
    }
    
    pub fn add_entity<E, P: Projection<E>>(&mut self, entity: &E, projection: &P) {
        let doc_id = DocId::new(self.next_doc_id);
        self.next_doc_id = self.next_doc_id.saturating_add(1);
        
        // Collect terms for each field
        let mut field_terms: BTreeMap<FieldId, Vec<(TermId, u32)>> = BTreeMap::new();
        
        projection.for_each_text_field(entity, &mut |field_id, text| {
            // Simple tokenization by whitespace
            let terms: Vec<&str> = text.split_whitespace().collect();
            let mut term_counts: BTreeMap<&str, u32> = BTreeMap::new();
            
            for term in terms {
                *term_counts.entry(term).or_insert(0) = term_counts.entry(term).or_insert(0).saturating_add(1);
            }
            
            for (term, count) in term_counts {
                let term_id = self.term_dict.insert(term);
                field_terms.entry(field_id).or_default().push((term_id, count));
            }
        });
        
        // Add postings for each term
        for (_field_id, terms) in field_terms {
            for (term_id, term_freq) in terms {
                let _posting = Posting {
                    doc_id,
                    term_freq,
                    positions: None,
                };
                
                // Get or create postings list for this term
                // Since InMemoryPostings doesn't have a mutable getter, we need to
                // accumulate postings separately
                // For now, just add directly (this is a simplified implementation)
                let _list = PostingsList::new(term_id);
                // Note: This is incomplete - we'd need a better approach
            }
        }
    }
    
    pub fn finish(self) -> InMemoryIndex {
        InMemoryIndex {
            postings: self.postings,
            term_dict: self.term_dict,
        }
    }
}

impl Default for InMemoryIndexBuilder {
    fn default() -> Self {
        Self::new()
    }
}

/// In-memory search index
pub struct InMemoryIndex {
    postings: InMemoryPostings,
    term_dict: TermDictionary,
}

impl InMemoryIndex {
    pub fn create_execution_plan(&self, query: &QueryProgram) -> ExecutionPlan {
        ExecutionPlan::new(query.clone())
    }
    
    pub fn execute<Id: EntityId, C: Collector<Id>>(
        &self,
        _plan: &ExecutionPlan,
        _workspace: &mut ExecutionWorkspace,
        _collector: &mut C,
    ) -> Vec<Hit<Id>> {
        // Placeholder implementation - just return empty for now
        // Real implementation would:
        // 1. Parse query terms from plan
        // 2. Look up term IDs in term_dict
        // 3. Get postings from postings index
        // 4. Score and collect results
        Vec::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use alloc::string::String;
    use alloc::string::ToString;

    /// A simple test entity with an id and text field
    #[derive(Debug, Clone)]
    struct TestEntity {
        id: u32,
        text: String,
    }

    /// A test projection that extracts id and text from TestEntity
    struct TestProjection;

    impl Projection<TestEntity> for TestProjection {
        type Id = u32;

        fn entity_id(&self, entity: &TestEntity) -> Self::Id {
            entity.id
        }

        fn for_each_text_field(&self, entity: &TestEntity, f: &mut dyn FnMut(FieldId, &str)) {
            // Use a simple field ID (0 for the text field)
            f(FieldId::new(0), &entity.text);
        }
    }

    #[test]
    fn test_projection_entity_id() {
        let entity = TestEntity {
            id: 42,
            text: "hello world".to_string(),
        };
        let projection = TestProjection;

        let id = projection.entity_id(&entity);
        assert_eq!(id, 42, "entity_id should return the correct ID");
    }

    #[test]
    fn test_projection_for_each_text_field() {
        let entity = TestEntity {
            id: 1,
            text: "hello world".to_string(),
        };
        let projection = TestProjection;

        let mut fields_visited = 0;
        let mut captured_field_id = None;
        let mut captured_text = None;

        projection.for_each_text_field(&entity, &mut |field_id, text| {
            fields_visited += 1;
            captured_field_id = Some(field_id);
            captured_text = Some(text.to_string());
        });

        assert_eq!(fields_visited, 1, "Should visit exactly one text field");
        assert_eq!(captured_field_id, Some(FieldId::new(0)), "Field ID should be 0");
        assert_eq!(captured_text, Some("hello world".to_string()), "Text should match");
    }

    #[test]
    fn test_projection_with_empty_text() {
        let entity = TestEntity {
            id: 99,
            text: "".to_string(),
        };
        let projection = TestProjection;

        let mut fields_visited = 0;
        let mut captured_text = None;

        projection.for_each_text_field(&entity, &mut |field_id, text| {
            fields_visited += 1;
            captured_text = Some(text.to_string());
        });

        assert_eq!(fields_visited, 1, "Should still visit the field even if empty");
        assert_eq!(captured_text, Some("".to_string()), "Empty text should be captured");
    }

    #[test]
    fn test_projection_with_multi_word_text() {
        let entity = TestEntity {
            id: 5,
            text: "the quick brown fox".to_string(),
        };
        let projection = TestProjection;

        let mut captured_text = None;

        projection.for_each_text_field(&entity, &mut |field_id, text| {
            captured_text = Some(text.to_string());
        });

        assert_eq!(
            captured_text,
            Some("the quick brown fox".to_string()),
            "Multi-word text should be captured correctly"
        );
    }
}
